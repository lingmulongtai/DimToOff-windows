<Window
    x:Class="DimToOff.Settings.TrayMenuWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="MenuRoot"
        Width="286"
        Height="334"
        Background="#2B2B2B"
        RequestedTheme="Dark">
        <Grid.Resources>
            <Style x:Key="MenuButtonStyle" TargetType="Button">
                <Setter Property="Height" Value="40" />
                <Setter Property="Padding" Value="10,0" />
                <Setter Property="HorizontalAlignment" Value="Stretch" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="Foreground" Value="#F3F3F3" />
                <Setter Property="FontSize" Value="14" />
            </Style>
        </Grid.Resources>

        <Border
            Padding="4"
            CornerRadius="8"
            Background="#F02B2B2B"
            BorderBrush="#484848"
            BorderThickness="1">
            <StackPanel>
                <Button Style="{StaticResource MenuButtonStyle}" Click="EnabledButton_Click">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            x:Name="EnabledCheck"
                            Glyph="&#xE73E;"
                            FontSize="13"
                            Foreground="#D7D7D7"
                            VerticalAlignment="Center" />
                        <TextBlock
                            Grid.Column="1"
                            Text="Enabled"
                            VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <Rectangle Height="1" Fill="#3D3D3D" Margin="8,5" />

                <Button Style="{StaticResource MenuButtonStyle}" Click="BlankButton_Click">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE706;" FontSize="16" Foreground="#D7D7D7" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="Blank screen now" VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource MenuButtonStyle}" Click="RestoreButton_Click">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE72C;" FontSize="16" Foreground="#D7D7D7" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="Restore brightness" VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource MenuButtonStyle}" Click="SettingsButton_Click">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE713;" FontSize="16" Foreground="#D7D7D7" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="Settings" VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <Rectangle Height="1" Fill="#3D3D3D" Margin="8,5" />

                <Button Style="{StaticResource MenuButtonStyle}" Click="StartWithWindowsButton_Click">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            x:Name="StartWithWindowsCheck"
                            Glyph="&#xE73E;"
                            FontSize="13"
                            Foreground="#D7D7D7"
                            VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="Open at boot" VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <Button Style="{StaticResource MenuButtonStyle}" Click="GitHubButton_Click">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE71B;" FontSize="16" Foreground="#D7D7D7" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="GitHub" VerticalAlignment="Center" />
                    </Grid>
                </Button>

                <Rectangle Height="1" Fill="#3D3D3D" Margin="8,5" />

                <Button Style="{StaticResource MenuButtonStyle}" Click="ExitButton_Click">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE7E8;" FontSize="16" Foreground="#D7D7D7" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="1" Text="Exit" VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>
