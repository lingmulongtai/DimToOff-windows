<Window
    x:Class="DimToOff.Settings.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        MinWidth="744"
        MinHeight="620"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="Margin" Value="2,18,0,2" />
            </Style>

            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Width" Value="672" />
                <Setter Property="HorizontalAlignment" Value="Left" />
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="18,14" />
            </Style>

            <Style x:Key="RowTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="TextWrapping" Value="WrapWholeWords" />
            </Style>

            <Style x:Key="RowDetailStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="WrapWholeWords" />
                <Setter Property="Margin" Value="0,4,0,0" />
            </Style>

            <Style x:Key="SuffixStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="72" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            ColumnSpacing="10"
            Padding="16,0,140,0"
            VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="28" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Viewbox
                Width="24"
                Height="24"
                VerticalAlignment="Center">
                <Grid Width="32" Height="32">
                    <Path
                        Data="M 7.5 8.5 L 24.5 8.5 Q 27 8.5 27 11 L 27 20 Q 27 22.5 24.5 22.5 L 7.5 22.5 Q 5 22.5 5 20 L 5 11 Q 5 8.5 7.5 8.5 Z"
                        Stroke="White"
                        StrokeThickness="2.6"
                        StrokeLineJoin="Round"
                        Fill="Transparent" />
                    <Path
                        Data="M 16 22.5 L 16 25.5 M 11.5 26 L 20.5 26"
                        Stroke="White"
                        StrokeThickness="2.4"
                        StrokeStartLineCap="Round"
                        StrokeEndLineCap="Round" />
                </Grid>
            </Viewbox>

            <TextBlock
                Grid.Column="1"
                Text="DimToOff"
                FontSize="13"
                FontWeight="SemiBold"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
        </Grid>

        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto">
            <StackPanel
                x:Name="ContentColumn"
                Width="720"
                Spacing="10"
                Padding="24,18,24,28"
                HorizontalAlignment="Left">

                <Grid ColumnSpacing="16" Margin="0,0,0,8">
                    <StackPanel Spacing="4">
                        <TextBlock
                            Text="Settings"
                            FontSize="30"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock
                            Text="Tuned for screen blanking that keeps Windows awake."
                            FontSize="13"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </Grid>

                <TextBlock Text="General" Style="{StaticResource SectionTitleStyle}" />

                <Border Style="{StaticResource CardStyle}">
                    <Grid Width="636" ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400" />
                            <ColumnDefinition Width="216" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Enable DimToOff" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Watch brightness changes and blank the screen at the threshold." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="EnabledToggle"
                            Grid.Column="1"
                            Width="48"
                            MinWidth="0"
                            OnContent=""
                            OffContent=""
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid Width="636" ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400" />
                            <ColumnDefinition Width="216" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Start with Windows" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Register DimToOff for the current Windows user." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="StartWithWindowsToggle"
                            Grid.Column="1"
                            Width="48"
                            MinWidth="0"
                            OnContent=""
                            OffContent=""
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid Width="636" ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400" />
                            <ColumnDefinition Width="216" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Error notifications" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Show a tray notification when restore or blanking fails." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="ErrorNotificationsToggle"
                            Grid.Column="1"
                            Width="48"
                            MinWidth="0"
                            OnContent=""
                            OffContent=""
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right" />
                    </Grid>
                </Border>

                <TextBlock Text="Blanking" Style="{StaticResource SectionTitleStyle}" />

                <Border Style="{StaticResource CardStyle}">
                    <Grid Width="636" ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400" />
                            <ColumnDefinition Width="216" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Mode" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Blackout keeps Windows awake and unlocked." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <ComboBox
                            x:Name="DisplayModeCombo"
                            Grid.Column="1"
                            Width="200"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            SelectionChanged="DisplayModeCombo_SelectionChanged">
                            <ComboBoxItem Content="Blackout overlay" Tag="Blackout" />
                            <ComboBoxItem Content="Monitor power request" Tag="MonitorPower" />
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid Width="636" ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400" />
                            <ColumnDefinition Width="216" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Off threshold" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Brightness at or below this value starts blanking." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                x:Name="OffThresholdBox"
                                Minimum="0"
                                Maximum="10"
                                SmallChange="1"
                                SpinButtonPlacementMode="Compact" />
                            <TextBlock Grid.Column="1" Text="%" Style="{StaticResource SuffixStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid Width="636" ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400" />
                            <ColumnDefinition Width="216" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Fade to black" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Smooths the overlay transition." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                x:Name="FadeToBlackBox"
                                Minimum="0"
                                Maximum="1200"
                                SmallChange="20"
                                SpinButtonPlacementMode="Compact" />
                            <TextBlock Grid.Column="1" Text="ms" Style="{StaticResource SuffixStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid Width="636" ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400" />
                            <ColumnDefinition Width="216" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Ignore input after blank" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Filters touchpad or mouse noise right after blanking." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                x:Name="IgnoreInputBox"
                                Minimum="300"
                                Maximum="2000"
                                SmallChange="100"
                                SpinButtonPlacementMode="Compact" />
                            <TextBlock Grid.Column="1" Text="ms" Style="{StaticResource SuffixStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Text="Timing" Style="{StaticResource SectionTitleStyle}" />

                <Border Style="{StaticResource CardStyle}">
                    <Grid Width="636" ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400" />
                            <ColumnDefinition Width="216" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Debounce" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Wait time before blanking after brightness reaches the threshold." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                x:Name="DebounceBox"
                                Minimum="300"
                                Maximum="2000"
                                SmallChange="100"
                                SpinButtonPlacementMode="Compact" />
                            <TextBlock Grid.Column="1" Text="ms" Style="{StaticResource SuffixStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid Width="636" ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400" />
                            <ColumnDefinition Width="216" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Cooldown" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Prevents immediate re-triggering after restore." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                x:Name="CooldownBox"
                                Minimum="1500"
                                Maximum="5000"
                                SmallChange="100"
                                SpinButtonPlacementMode="Compact" />
                            <TextBlock Grid.Column="1" Text="ms" Style="{StaticResource SuffixStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid Width="636" ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400" />
                            <ColumnDefinition Width="216" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Brightness save stable time" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Only stable brightness is remembered for restore." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                x:Name="BrightnessStableBox"
                                Minimum="1000"
                                Maximum="10000"
                                SmallChange="250"
                                SpinButtonPlacementMode="Compact" />
                            <TextBlock Grid.Column="1" Text="ms" Style="{StaticResource SuffixStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Text="Restore" Style="{StaticResource SectionTitleStyle}" />

                <Border Style="{StaticResource CardStyle}">
                    <Grid Width="636" ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400" />
                            <ColumnDefinition Width="216" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Minimum restore brightness" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Restore brightness will never be lower than this." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                x:Name="MinimumRestoreBox"
                                Minimum="30"
                                Maximum="100"
                                SmallChange="1"
                                SpinButtonPlacementMode="Compact" />
                            <TextBlock Grid.Column="1" Text="%" Style="{StaticResource SuffixStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid Width="636" ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="400" />
                            <ColumnDefinition Width="216" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Default restore brightness" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Used until a stable brightness has been learned." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                x:Name="DefaultRestoreBox"
                                Minimum="30"
                                Maximum="100"
                                SmallChange="1"
                                SpinButtonPlacementMode="Compact" />
                            <TextBlock Grid.Column="1" Text="%" Style="{StaticResource SuffixStyle}" />
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border
            Grid.Row="2"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid Padding="28,14" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Button
                    Content="GitHub"
                    Click="GitHubButton_Click"
                    HorizontalAlignment="Left"
                    BorderBrush="#164C8F"
                    BorderThickness="1" />

                <InfoBar
                    x:Name="SaveInfoBar"
                    Grid.Column="1"
                    IsOpen="False"
                    IsClosable="True"
                    Severity="Success"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Stretch"
                    MaxWidth="420" />

                <StackPanel
                    Grid.Column="2"
                    Orientation="Horizontal"
                    Spacing="10"
                    HorizontalAlignment="Right">
                    <Button Content="Close" Click="CloseButton_Click" />
                    <Button
                        Content="Save"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="SaveButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
