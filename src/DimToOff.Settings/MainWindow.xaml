<Window
    x:Class="DimToOff.Settings.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        MinWidth="820"
        MinHeight="620"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.Resources>
            <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="Margin" Value="2,18,0,2" />
            </Style>

            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="18,14" />
            </Style>

            <Style x:Key="RowTitleStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
                <Setter Property="TextWrapping" Value="WrapWholeWords" />
            </Style>

            <Style x:Key="RowDetailStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="TextWrapping" Value="WrapWholeWords" />
                <Setter Property="Margin" Value="0,4,0,0" />
            </Style>

            <Style x:Key="SuffixStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
            <RowDefinition Height="72" />
        </Grid.RowDefinitions>

        <Grid
            x:Name="AppTitleBar"
            Grid.Row="0"
            ColumnSpacing="10"
            Padding="16,0,140,0"
            VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="28" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Width="24"
                Height="24"
                CornerRadius="6"
                Background="{ThemeResource AccentFillColorDefaultBrush}"
                VerticalAlignment="Center">
                <TextBlock
                    Text="D"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
            </Border>

            <TextBlock
                Grid.Column="1"
                Text="DimToOff"
                FontSize="13"
                FontWeight="SemiBold"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
        </Grid>

        <ScrollViewer
            Grid.Row="1"
            HorizontalScrollBarVisibility="Disabled"
            HorizontalScrollMode="Disabled"
            VerticalScrollBarVisibility="Auto"
            VerticalScrollMode="Auto">
            <StackPanel
                MaxWidth="880"
                Spacing="10"
                Padding="28,18,28,28"
                HorizontalAlignment="Stretch">

                <Grid ColumnSpacing="16" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Spacing="4">
                        <TextBlock
                            Text="Settings"
                            FontSize="30"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <TextBlock
                            Text="Tuned for screen blanking that keeps Windows awake."
                            FontSize="13"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <Border
                        Grid.Column="1"
                        Height="32"
                        Padding="12,0"
                        CornerRadius="16"
                        Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                        VerticalAlignment="Top">
                        <TextBlock
                            x:Name="StatusText"
                            Text="Ready"
                            FontSize="12"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                            VerticalAlignment="Center" />
                    </Border>
                </Grid>

                <TextBlock Text="General" Style="{StaticResource SectionTitleStyle}" />

                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Enable DimToOff" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Watch brightness changes and blank the screen at the threshold." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="EnabledToggle"
                            Grid.Column="1"
                            MinWidth="0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Toggled="EnabledToggle_Toggled" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Start with Windows" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Register DimToOff for the current Windows user." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="StartWithWindowsToggle"
                            Grid.Column="1"
                            MinWidth="0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right" />
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Error notifications" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Show a tray notification when restore or blanking fails." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <ToggleSwitch
                            x:Name="ErrorNotificationsToggle"
                            Grid.Column="1"
                            MinWidth="0"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right" />
                    </Grid>
                </Border>

                <TextBlock Text="Blanking" Style="{StaticResource SectionTitleStyle}" />

                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Mode" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Blackout keeps Windows awake and unlocked." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <ComboBox
                            x:Name="DisplayModeCombo"
                            Grid.Column="1"
                            Width="220"
                            VerticalAlignment="Center"
                            SelectionChanged="DisplayModeCombo_SelectionChanged">
                            <ComboBoxItem Content="Blackout overlay" Tag="Blackout" />
                            <ComboBoxItem Content="Monitor power request" Tag="MonitorPower" />
                        </ComboBox>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Off threshold" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Brightness at or below this value starts blanking." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                x:Name="OffThresholdBox"
                                Minimum="0"
                                Maximum="10"
                                SmallChange="1"
                                SpinButtonPlacementMode="Compact" />
                            <TextBlock Grid.Column="1" Text="%" Style="{StaticResource SuffixStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Fade to black" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Smooths the overlay transition." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                x:Name="FadeToBlackBox"
                                Minimum="0"
                                Maximum="1200"
                                SmallChange="20"
                                SpinButtonPlacementMode="Compact" />
                            <TextBlock Grid.Column="1" Text="ms" Style="{StaticResource SuffixStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Ignore input after blank" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Filters touchpad or mouse noise right after blanking." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                x:Name="IgnoreInputBox"
                                Minimum="300"
                                Maximum="2000"
                                SmallChange="100"
                                SpinButtonPlacementMode="Compact" />
                            <TextBlock Grid.Column="1" Text="ms" Style="{StaticResource SuffixStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Text="Timing" Style="{StaticResource SectionTitleStyle}" />

                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Debounce" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Wait time before blanking after brightness reaches the threshold." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                x:Name="DebounceBox"
                                Minimum="300"
                                Maximum="2000"
                                SmallChange="100"
                                SpinButtonPlacementMode="Compact" />
                            <TextBlock Grid.Column="1" Text="ms" Style="{StaticResource SuffixStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Cooldown" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Prevents immediate re-triggering after restore." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                x:Name="CooldownBox"
                                Minimum="1500"
                                Maximum="5000"
                                SmallChange="100"
                                SpinButtonPlacementMode="Compact" />
                            <TextBlock Grid.Column="1" Text="ms" Style="{StaticResource SuffixStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Brightness save stable time" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Only stable brightness is remembered for restore." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                x:Name="BrightnessStableBox"
                                Minimum="1000"
                                Maximum="10000"
                                SmallChange="250"
                                SpinButtonPlacementMode="Compact" />
                            <TextBlock Grid.Column="1" Text="ms" Style="{StaticResource SuffixStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock Text="Restore" Style="{StaticResource SectionTitleStyle}" />

                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Minimum restore brightness" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Restore brightness will never be lower than this." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                x:Name="MinimumRestoreBox"
                                Minimum="30"
                                Maximum="100"
                                SmallChange="1"
                                SpinButtonPlacementMode="Compact" />
                            <TextBlock Grid.Column="1" Text="%" Style="{StaticResource SuffixStyle}" />
                        </Grid>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Default restore brightness" Style="{StaticResource RowTitleStyle}" />
                            <TextBlock Text="Used until a stable brightness has been learned." Style="{StaticResource RowDetailStyle}" />
                        </StackPanel>
                        <Grid Grid.Column="1" ColumnSpacing="8" VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="142" />
                                <ColumnDefinition Width="34" />
                            </Grid.ColumnDefinitions>
                            <NumberBox
                                x:Name="DefaultRestoreBox"
                                Minimum="30"
                                Maximum="100"
                                SmallChange="1"
                                SpinButtonPlacementMode="Compact" />
                            <TextBlock Grid.Column="1" Text="%" Style="{StaticResource SuffixStyle}" />
                        </Grid>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border
            Grid.Row="2"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <Grid Padding="28,14" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <InfoBar
                    x:Name="SaveInfoBar"
                    IsOpen="False"
                    IsClosable="True"
                    Severity="Success"
                    VerticalAlignment="Center"
                    MaxWidth="420" />

                <StackPanel
                    Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="10"
                    HorizontalAlignment="Right">
                    <Button Content="GitHub" Click="GitHubButton_Click" />
                    <Button Content="Close" Click="CloseButton_Click" />
                    <Button
                        Content="Save"
                        Style="{StaticResource AccentButtonStyle}"
                        Click="SaveButton_Click" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
